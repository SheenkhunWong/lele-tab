{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "short_name": "LeLe Tab",
  "description": "__MSG_extDescription__",
  "version": "1.0.0",
  "default_locale": "zh_CN",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "sw.js",
    "type": "module"
  },
  "oauth2": {
    "client_id": "",
    "scopes": ["https://www.googleapis.com/auth/drive.file"]
  },
  "permissions": ["tabs", "storage", "identity", "bookmarks", "alarms"],
  "host_permissions": ["https://www.googleapis.com/*", "https://api.open-meteo.com/*", "https://geocoding-api.open-meteo.com/*"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "LeLe Tab"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
