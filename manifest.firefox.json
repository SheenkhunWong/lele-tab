{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "short_name": "LeLe Tab",
  "description": "__MSG_extDescription__",
  "version": "1.0.0",
  "default_locale": "zh_CN",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "scripts": ["sw.js"],
    "type": "module"
  },
  "permissions": ["tabs", "storage", "identity", "bookmarks", "alarms"],
  "host_permissions": ["https://www.googleapis.com/*", "https://api.open-meteo.com/*", "https://geocoding-api.open-meteo.com/*"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "lele-tab@example.com",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
